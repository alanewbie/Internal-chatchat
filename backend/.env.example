AWS_REGION=us-east-1

# Aurora PostgreSQL
RDS_HOST=database-1-instance-1.c2hkuqg2i7op.us-east-1.rds.amazonaws.com
RDS_PORT=5432
RDS_DATABASE=postgres
RDS_USER=postgres
RDS_SSLMODE=require
RDS_USE_IAM_AUTH=true

# OpenSearch
OPENSEARCH_REGION=us-east-1
OPENSEARCH_DOMAIN_ARN=arn:aws:es:us-east-1:379683255100:domain/internalfile
OPENSEARCH_ENDPOINT=https://vpc-mydomain-rxg54uahgjrmy3bgoxgi2swbtm.us-east-1.es.amazonaws.com
OPENSEARCH_VECTOR_INDEX=internal-chatchat-vectors
OPENSEARCH_EMBEDDING_DIMENSION=1024

# S3
S3_BUCKET=rag-files-folder
S3_REGION=us-east-1
S3_UPLOAD_PREFIX=uploads/
S3_PRIVATE_DOWNLOADS=true

# Bedrock
BEDROCK_REGION=us-east-1
BEDROCK_CHAT_MODEL_ID=anthropic.claude-opus-4-5-20251101-v1:0
BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# Cognito
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=
COGNITO_APP_CLIENT_ID=
